<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Required for network fetches (GitHub Pages JSON refresh) and Google Maps. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Location — used to show the user's position on the trails and follow the route. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- Photo picker for POI photos (local-only, never uploaded). -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- Google Play Billing (in_app_purchase plugin also auto-merges this,
         declared explicitly for clarity). -->
    <uses-permission android:name="com.android.vending.BILLING"/>

    <application
        android:label="Woodlands Trail Guide"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:largeHeap="true">

        <!-- Google Maps API key. Restrict in Google Cloud Console → Credentials →
             this key → Android apps → package name + SHA-1. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyBeonDXHhgPNczFoR-ilpzTl2ZvzOecKE0"/>

        <!-- AdMob App ID — this is GOOGLE'S OFFICIAL TEST APP ID, safe to
             ship during development (shows clearly-labeled test ads only,
             never flagged by Google). Replace with the real Android App ID
             once registered in AdMob — the existing iOS App ID does NOT
             carry over; Android needs its own app entry in the same
             publisher account. See README.md "AdMob setup". -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713"/>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Share-a-route deep link:
                 woodlandstrailguide://route?start=LAT,LON&end=LAT,LON&via=LAT,LON|LAT,LON -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="woodlandstrailguide" android:host="route"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Disable WorkManager's default auto-initialization. We don't use
             WorkManager directly anywhere in this app — it's only pulled in
             transitively (by google_mobile_ads and/or geolocator_android).
             google_mobile_ads' own internal startup code piggybacks on the
             shared androidx.startup.InitializationProvider to build
             WorkManager's Room database on app launch, and that build was
             crashing at startup (FATAL EXCEPTION: main ->
             "Failed to create an instance of androidx.work.impl.WorkDatabase").
             Removing WorkManagerInitializer from the shared provider stops
             that code path from running at all — safe here since nothing in
             this app relies on WorkManager's persisted background jobs. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
